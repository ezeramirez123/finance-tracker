# Postgres connection string (e.g. from Vercel Postgres, Neon, or Supabase)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Auth.js session encryption secret — generate with `npx auth secret` or `openssl rand -base64 33`
AUTH_SECRET=""

# Google OAuth client — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Required in production if the deployed URL isn't auto-detected (e.g. non-Vercel hosts)
# AUTH_URL="https://your-domain.com"

# Shared secret checked by /api/cron/refresh-rates against the Vercel Cron request
CRON_SECRET=""

# Plaid bank-linking — get free Sandbox keys at https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# Required in production for OAuth institutions (Chase, BofA, Wells Fargo, etc.)
# Must exactly match a URI registered under Team Settings > API > Allowed redirect URIs
# in the Plaid dashboard. Point it at the Accounts page, e.g. https://your-domain.com/accounts
# PLAID_REDIRECT_URI="https://your-domain.com/accounts"
